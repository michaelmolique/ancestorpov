// ─── LOAD FROM JSON ───────────────────────────────────────────────────────────
function loadFromJSON() {
  const raw = document.getElementById('json-input').value.trim();
  const errEl = document.getElementById('json-err');
  errEl.style.display = 'none';
  try {
    const data = JSON.parse(raw.replace(/```json|```/g,'').trim());
    if (!data.scenes || !Array.isArray(data.scenes) || data.scenes.length === 0) throw new Error('Missing or empty scenes array');
    if (!data.title) throw new Error('Missing title');

    const sceneCount = data.scenes.length;
    const mode = sceneCount <= 3 ? 'test' : 'full';

    // Build SRT
    const srt = data.scenes.map((s, i) => {
      return `${i+1}\n${toSRTTime(i*10)} --> ${toSRTTime((i+1)*10)}\n${s.caption || s.label}\n`;
    }).join('\n');

    S.current = { ...data, srt, mode, sceneCount };
    S.clips = {};
    data.scenes.forEach(s => { S.clips[s.id] = { status: 'waiting', blob: null, url: null, taskId: null }; });

    renderReview();
    goToStep(1);
    clearStatus();
  } catch(e) {
    errEl.textContent = '✕ ' + e.message;
    errEl.style.display = 'block';
  }
}

// ─── STEP 1: GENERATE SCRIPT (unused - kept for future API use) ───────────────
async function generateScript() {}

function toSRTTime(secs) {
  const h = Math.floor(secs/3600).toString().padStart(2,'0');
  const m = Math.floor((secs%3600)/60).toString().padStart(2,'0');
  const s = Math.floor(secs%60).toString().padStart(2,'0');
  return `${h}:${m}:${s},000`;
}

function renderReview() {
  const d = S.current;
  document.getElementById('review-title').textContent = d.title;
  document.getElementById('review-narration').textContent = d.narration;
  document.getElementById('review-captions').textContent = d.srt;
  document.getElementById('review-scenes').innerHTML = d.scenes.map((s,i) => `
    <div class="scene-card">
      <div class="scene-head">
        <div class="scene-num">SCENE ${i+1} · ${s.id*10-10}s–${s.id*10}s</div>
      </div>
      <div class="scene-label">${s.label}</div>
      <div class="scene-prompt">${s.videoPrompt.substring(0,140)}…</div>
      <div class="scene-caption">🎬 "${s.caption}"</div>
      <div style="font-size:11px;color:var(--dim);margin-top:4px;">🔊 ${s.soundPrompt}</div>
    </div>`).join('');
}

// ─── STEP 2: GENERATE CLIPS ───────────────────────────────────────────────────
async function startClips() {
  goToStep(2);
  renderClipCards();
  setStatus('run', `⟳ Submitting ${S.current.sceneCount} clips to Kling with native audio…`);

  for (const scene of S.current.scenes) {
    await submitClip(scene);
  }
  checkAllDone();
}

function renderClipCards() {
  document.getElementById('clip-count').textContent = `0 / ${S.current.sceneCount} clips ready`;
  document.getElementById('clips-list').innerHTML = S.current.scenes.map(s => `
    <div class="scene-card" id="cc-${s.id}">
      <div class="scene-head">
        <div class="scene-num">SCENE ${s.id}</div>
        <div class="scene-badge badge-wait" id="cb-${s.id}">Waiting</div>
      </div>
      <div class="scene-label">${s.label}</div>
      <div class="scene-prompt">${s.videoPrompt.substring(0,100)}…</div>
      <div id="cl-${s.id}"></div>
    </div>`).join('');
}

function setClipStatus(id, status, msg='') {
  const badge = document.getElementById('cb-'+id);
  const link = document.getElementById('cl-'+id);
  if (!badge) return;
  const labels = { waiting:'Waiting', submitting:'Submitting…', queued:'Queued…', generating:'Generating…', done:'✓ Ready', error:'✕ Failed' };
  const classes = { waiting:'badge-wait', submitting:'badge-run', queued:'badge-run', generating:'badge-run', done:'badge-done', error:'badge-err' };
  badge.textContent = labels[status] || status;
  badge.className = 'scene-badge ' + (classes[status] || 'badge-wait');
  if (msg && link) link.innerHTML = `<div class="scene-link">${msg}</div>`;
  updateClipProgress();
}

function updateClipProgress() {
  const total = S.current.sceneCount;
  const done = Object.values(S.clips).filter(c => c.status === 'done').length;
  const pct = Math.round(done / total * 100);
  document.getElementById('clip-prog').style.width = pct+'%';
  document.getElementById('clip-count').textContent = `${done} / ${total} clips ready`;
}

async function submitClip(scene) {
  const clip = S.clips[scene.id];
  clip.status = 'submitting';
  setClipStatus(scene.id, 'submitting');

  try {
    const res = await fetch(`${S.workerUrl}/fal/submit`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        input: {
          prompt: scene.videoPrompt,
          duration: '10',
          aspect_ratio: '9:16',
          negative_prompt: 'dialogue, talking, text overlay, watermark, blurry, low quality',
          generate_audio: true
        }
      })
    });
    const data = await res.json();
    if (!data.request_id) throw new Error(data.error || 'No request_id: ' + JSON.stringify(data).substring(0,80));
    clip.taskId = data.request_id;
    clip.status = 'queued';
    setClipStatus(scene.id, 'queued');
    await pollClip(scene.id, data.request_id);
  } catch(e) {
    clip.status = 'error';
    setClipStatus(scene.id, 'error', e.message.substring(0,80));
  }
}

async function pollClip(sceneId, requestId) {
  for (let i = 0; i < 120; i++) {
    await sleep(5000);
    try {
      const res = await fetch(`${S.workerUrl}/fal/status/${requestId}`);
      const data = await res.json();
      if (data.status === 'IN_QUEUE') { setClipStatus(sceneId, 'queued', `Queue position: ${data.queue_position ?? '…'}`); continue; }
      if (data.status === 'IN_PROGRESS') { setClipStatus(sceneId, 'generating'); continue; }
      if (data.status === 'COMPLETED') {
        const rRes = await fetch(`${S.workerUrl}/fal/result/${requestId}`);
        const result = await rRes.json();
        const videoUrl = result.video?.url || result.videos?.[0]?.url;
        if (!videoUrl) throw new Error('No video URL in result');
        S.clips[sceneId].url = videoUrl;
        S.clips[sceneId].status = 'done';
        setClipStatus(sceneId, 'done', `<a href="${videoUrl}" target="_blank">Download clip →</a>`);
        return;
      }
      if (data.status === 'FAILED') throw new Error(data.error || 'Generation failed');
    } catch(e) {
      if (i === 119) { S.clips[sceneId].status = 'error'; setClipStatus(sceneId, 'error', e.message.substring(0,60)); return; }
    }
  }
  S.clips[sceneId].status = 'error';
  setClipStatus(sceneId, 'error', 'Timed out — check fal.ai dashboard');
}

function checkAllDone() {
  const clips = Object.values(S.clips);
  const done = clips.filter(c => c.status === 'done').length;
  const failed = clips.filter(c => c.status === 'error').length;
  document.getElementById('clips-actions').style.display = 'flex';
  if (done === 0) {
    setStatus('err', '✕ All clips failed. Check worker URL and FAL_KEY in Cloudflare.');
  } else if (failed > 0) {
    setStatus('info', `⚠ ${done}/${S.current.sceneCount} clips ready. ${failed} failed — retry or assemble with available clips.`);
  } else {
    setStatus('ok', `✓ All ${done} clips ready with native audio. Click Assemble Video.`);
  }
}

async function retryFailed() {
  const failed = S.current.scenes.filter(s => S.clips[s.id].status === 'error');
  if (failed.length === 0) return;
  setStatus('run', `⟳ Retrying ${failed.length} failed clip(s)…`);
  document.getElementById('clips-actions').style.display = 'none';
  for (const scene of failed) {
    S.clips[scene.id] = { status: 'waiting', blob: null, url: null, taskId: null };
    await submitClip(scene);
  }
  checkAllDone();
}

// ─── STEP 3: ASSEMBLE ─────────────────────────────────────────────────────────
async function startAssemble() {
  goToStep(3);
  const readyClips = S.current.scenes.filter(s => S.clips[s.id]?.url);
  if (readyClips.length === 0) { setStatus('err', 'No clips available to assemble.'); return; }

  asmLog('Loading FFmpeg.wasm…');
  setAsmProg(5);

  try {
    if (!S.ffmpegReady) {
      const { FFmpeg } = FFmpegWASM;
      const { toBlobURL } = FFmpegUtil;
      S.ffmpeg = new FFmpeg();
      S.ffmpeg.on('log', ({ message }) => { if (message && !message.startsWith('ffmpeg version')) asmLog(message.substring(0,80)); });
      await S.ffmpeg.load({
        coreURL: await toBlobURL('https://unpkg.com/@ffmpeg/core@0.12.6/dist/umd/ffmpeg-core.js', 'text/javascript'),
        wasmURL: await toBlobURL('https://unpkg.com/@ffmpeg/core@0.12.6/dist/umd/ffmpeg-core.wasm', 'application/wasm'),
      });
      S.ffmpegReady = true;
    }
    asmLog('FFmpeg loaded ✓', 'log-ok');
    setAsmProg(15);

    // Download clips
    asmLog(`Downloading ${readyClips.length} clips…`);
    const { fetchFile } = FFmpegUtil;
    for (let i = 0; i < readyClips.length; i++) {
      const scene = readyClips[i];
      asmLog(`  Fetching clip ${i+1}/${readyClips.length}: ${scene.label}`);
      try {
        const data = await fetchFile(S.clips[scene.id].url);
        await S.ffmpeg.writeFile(`clip${i}.mp4`, data);
        asmLog(`  ✓ clip${i+1} saved`, 'log-ok');
      } catch(e) {
        // Try via proxy if direct fetch fails
        asmLog(`  Direct fetch failed, trying proxy…`);
        const proxyRes = await fetch(`${S.workerUrl}/proxy`, {
          method: 'POST', headers: {'Content-Type':'application/json'},
          body: JSON.stringify({ url: S.clips[scene.id].url })
        });
        const buf = await proxyRes.arrayBuffer();
        await S.ffmpeg.writeFile(`clip${i}.mp4`, new Uint8Array(buf));
        asmLog(`  ✓ clip${i+1} via proxy`, 'log-ok');
      }
      setAsmProg(15 + Math.round((i+1)/readyClips.length * 40));
    }

    // Write SRT
    asmLog('Writing captions…');
    const encoder = new TextEncoder();
    await S.ffmpeg.writeFile('captions.srt', encoder.encode(S.current.srt));

    // Build concat list
    const concatList = readyClips.map((_, i) => `file 'clip${i}.mp4'`).join('\n');
    await S.ffmpeg.writeFile('list.txt', encoder.encode(concatList));

    // Concat (stream copy — fast, no re-encode)
    asmLog('Concatenating clips…');
    setAsmProg(60);
    await S.ffmpeg.exec(['-f','concat','-safe','0','-i','list.txt','-c','copy','concat.mp4']);
    asmLog('Concat done ✓', 'log-ok');
    setAsmProg(75);

    // Burn captions (requires re-encode)
    asmLog('Burning captions…');
    await S.ffmpeg.exec([
      '-i','concat.mp4',
      '-vf', "subtitles=captions.srt:force_style='FontName=Arial,FontSize=14,PrimaryColour=&H00ffffff,Bold=1,Outline=2,OutlineColour=&H00000000,MarginV=60'",
      '-c:a','copy',
      '-c:v','libx264','-preset','fast','-crf','23',
      'output.mp4'
    ]);
    asmLog('Captions burned ✓', 'log-ok');
    setAsmProg(95);

    // Read output
    const outData = await S.ffmpeg.readFile('output.mp4');
    S.finalBlob = new Blob([outData.buffer], { type: 'video/mp4' });
    asmLog(`Final video ready — ${(S.finalBlob.size/1024/1024).toFixed(1)}MB ✓`, 'log-ok');
    setAsmProg(100);

    setTimeout(() => showDone(), 800);

  } catch(e) {
    asmLog('Error: ' + e.message, 'log-err');
    setStatus('err', '✕ Assembly failed: ' + e.message.substring(0,100));
    // Fallback: show individual clip links
    asmLog('Falling back to individual clip links…');
    showFallbackDone();
  }
}

function showDone() {
  goToStep(4);
  document.getElementById('done-title').textContent = S.current.title;
  document.getElementById('done-caption').textContent = S.current.postCaption;
  document.getElementById('done-hashtags').textContent = S.current.hashtags;

  // Video download
  const videoUrl = URL.createObjectURL(S.finalBlob);
  const dlBtn = document.getElementById('dl-video-btn');
  dlBtn.onclick = () => { const a = document.createElement('a'); a.href = videoUrl; a.download = 'ancestorpov.mp4'; a.click(); };

  // SRT download
  const srtBlob = new Blob([S.current.srt], { type: 'text/plain' });
  const srtUrl = URL.createObjectURL(srtBlob);
  document.getElementById('dl-srt-btn').onclick = () => { const a = document.createElement('a'); a.href = srtUrl; a.download = 'ancestorpov.srt'; a.click(); };
}

function showFallbackDone() {
  goToStep(4);
  document.getElementById('done-title').textContent = S.current.title;
  document.getElementById('done-caption').textContent = S.current.postCaption;
  document.getElementById('done-hashtags').textContent = S.current.hashtags;
  document.getElementById('dl-video-btn').style.display = 'none';

  // Show individual clip links
  const readyClips = S.current.scenes.filter(s => S.clips[s.id]?.url);
  const srtBlob = new Blob([S.current.srt], { type: 'text/plain' });
  const srtUrl = URL.createObjectURL(srtBlob);
  document.getElementById('dl-srt-btn').onclick = () => { const a = document.createElement('a'); a.href = srtUrl; a.download = 'ancestorpov.srt'; a.click(); };

  const card = document.querySelector('.card.done-hero');
  card.innerHTML += `<div style="margin-top:16px;text-align:left;">
    <div style="font-size:11px;color:var(--dim);letter-spacing:.08em;text-transform:uppercase;margin-bottom:8px;">Individual Clips</div>
    ${readyClips.map((s,i) => `<div style="margin-bottom:6px;font-size:12px;">Scene ${i+1}: <a href="${S.clips[s.id].url}" target="_blank" style="color:#6a9fd4;">${s.label} →</a></div>`).join('')}
    <div style="margin-top:10px;font-size:12px;color:var(--dim);">Download clips + SRT and assemble in CapCut or any video editor.</div>
  </div>`;
}

function copyCaption() {
  const text = document.getElementById('done-caption').textContent + '\n\n' + document.getElementById('done-hashtags').textContent;
  navigator.clipboard.writeText(text);
}

function newVideo() {
  S.current = null; S.clips = {}; S.finalBlob = null;
  document.getElementById('topic').value = '';
  goToStep(0);
}

// ─── UTILS ────────────────────────────────────────────────────────────────────
const sleep = ms => new Promise(r => setTimeout(r, ms));

// ─── INIT ─────────────────────────────────────────────────────────────────────
document.getElementById('s-worker').value = S.workerUrl;
